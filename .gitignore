# Rust workspace build output
/target/

# OS
.DS_Store

# Generated by scripts/bootstrap.sh (local OPENSSL_DIR etc.)
/.env.bootstrap

# Real secrets an operator fills in from infra/*.env.example (TURN
# credentials, push-relay domain, etc.) — must never land in git history.
# Keep the *.example templates tracked; only the filled-in copies are
# ignored.
infra/.env
**/*.env
!**/*.env.example

# Claude Code local session/tooling state (worktrees, local settings)
/.claude/
