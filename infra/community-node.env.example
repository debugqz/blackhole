# Copy to infra/community-node.env and fill in real values before:
#   docker compose -f infra/docker-compose.community-node.yml \
#     --env-file infra/community-node.env up -d --build
# See infra/COMMUNITY_NODE_GUIDE.md for the full walkthrough.

# The multiaddr(es) of already-running bootstrap node(s) to join — get
# this from whoever you want your node to help (the platform operator's
# published list, a community chat, etc). Comma-separate more than one;
# do include more than one if you were given more than one, so your node
# still finds the network if one of them is temporarily down.
#
# Format: /ip4/<their public IP>/tcp/<their port>/p2p/<their PeerId>
BLACKHOLE_BOOTSTRAP_PEERS=/ip4/203.0.113.10/tcp/4001/p2p/12D3KooWExamplePeerIdGoesHere

# Public port your own node's DHT listener is reachable on. Only change
# this if 4001 is already taken on your host — remember to update your
# firewall/router port-forward to match whatever you pick.
COMMUNITY_NODE_PUBLIC_PORT=4001
