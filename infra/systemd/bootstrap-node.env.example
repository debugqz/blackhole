# Copy to /etc/blackhole/bootstrap-node.env (mode 600, owned by the
# `blackhole` service user — this file's contents feed the platform
# keystore path below, treat it like any other secrets file) and fill in
# real values. See ../../README.md for the full walkthrough.

BLACKHOLE_DATA_DIR=/var/lib/blackhole/data

# A bootstrap node's whole point is a stable, publicly reachable identity
# — see docs/THREAT_MODEL.md §3.5/§3.7 for why both of these are off by
# default for an ordinary end-user daemon but wanted here.
BLACKHOLE_PERSISTENT_NETWORK_IDENTITY=1
# Bare-metal note: if this host actually has a Secret Service provider
# running (gnome-keyring/kwallet) under the `blackhole` service user's
# session, you can drop this line and use the real OS keychain instead —
# BLACKHOLE_KEYSTORE_BACKEND=file exists specifically for the common case
# (a systemd service with no desktop session at all) where it doesn't.
BLACKHOLE_KEYSTORE_BACKEND=file

# Fixed port so the multiaddr you publish doesn't change on its own.
BLACKHOLE_NETWORK_LISTEN_ADDR=/ip4/0.0.0.0/tcp/4001

# Leave empty for the very first bootstrap node in a deployment; point at
# an existing one's multiaddr for every subsequent node so they all end up
# in the same DHT rather than founding isolated islands.
BLACKHOLE_BOOTSTRAP_PEERS=
