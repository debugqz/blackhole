# Copy to infra/.env and fill in real values before `docker compose up`.
# See infra/README.md for the full walkthrough of what each piece is and
# the order to bring them up in.

# ---- bootstrap-node -------------------------------------------------
# Public host/IP this node is reachable at — used only to construct the
# multiaddr you'll hand out to clients after the container starts (see
# README "Publishing the bootstrap address"). Not read by the daemon
# itself.
BOOTSTRAP_PUBLIC_HOST=bootstrap1.example.org
BOOTSTRAP_PUBLIC_PORT=4001

# ---- push-relay -------------------------------------------------------
PUSH_RELAY_DOMAIN=push-relay.example.org
PUSH_RELAY_PORT=47900

# ---- coturn -------------------------------------------------------
# A single static long-term-credential user (coturn's `lt-cred-mech`) —
# matches what bh-calls::transport::default_ice_servers actually supports
# today (BLACKHOLE_TURN_USERNAME/_CREDENTIAL is one fixed pair, not
# coturn's time-limited REST/use-auth-secret scheme). Generate a real
# secret, don't ship this example value:
#   openssl rand -hex 32
TURN_REALM=turn.example.org
TURN_USERNAME=blackhole
TURN_CREDENTIAL=change-me-to-a-real-random-secret
# Public IP of the coturn host — coturn needs this to hand out correct
# relay candidates to clients behind NAT (its `external-ip` setting).
TURN_PUBLIC_IP=203.0.113.10
